PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Optional password — if set, the UI prompts once and stores it in localStorage.
# Leave empty (or unset) to disable auth entirely.
DASHBOARD_PASSWORD=
DASHBOARD_TITLE=Family Dashboard

# Immich
IMMICH_BASE_URL=https://your-immich.example.com
IMMICH_API_KEY=replace-me
# Comma-separated person UUIDs (the dashboard ORs across these)
IMMICH_PERSON_IDS=uuid1,uuid2,uuid3
IMMICH_PHOTO_INTERVAL_SECONDS=300

# Weather (Open-Meteo, no API key)
WEATHER_LATITUDE=60.17
WEATHER_LONGITUDE=24.94
WEATHER_TIMEZONE=Europe/Helsinki

# Home Assistant
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=replace-me

# Calendar (sourced from HA's Google Calendar integration)
CALENDAR_ENTITIES=calendar.family,calendar.hobbies
CALENDAR_DAYS_AHEAD=5

# Sensors (up to 20, sequential — stop at first gap)
# ENTITY: Home Assistant entity_id (required)
# LABEL:  display name
# UNIT:   display unit
# DECIMALS: decimal places after rounding (default 0)
# MULTIPLIER: multiply raw value before rounding (default 1, use e.g. 0.001 to convert W→kW)
# SHOW_ABOVE: only show this sensor when its raw value exceeds this threshold
SENSOR_1_ENTITY=sensor.ulkolampotila
SENSOR_1_LABEL=Lämpötila
SENSOR_1_UNIT=°C

SENSOR_2_ENTITY=sensor.palju_vesi
SENSOR_2_LABEL=Palju
SENSOR_2_UNIT=°C
SENSOR_2_SHOW_ABOVE=25

SENSOR_3_ENTITY=sensor.sauna_lampotila
SENSOR_3_LABEL=Sauna
SENSOR_3_UNIT=°C
SENSOR_3_SHOW_ABOVE=40

SENSOR_4_ENTITY=sensor.inverter_pv_power
SENSOR_4_LABEL=Tuotantoteho
SENSOR_4_UNIT=kW
SENSOR_4_MULTIPLIER=0.001
SENSOR_4_DECIMALS=1

SENSOR_5_ENTITY=sensor.inverter_today_production
SENSOR_5_LABEL=Tuotanto tänään
SENSOR_5_UNIT=kWh
SENSOR_5_DECIMALS=1

# Electricity color thresholds (c/kWh, with VAT)
# < ELEC_GREEN_BELOW → green; > ELEC_RED_ABOVE → red; in between → yellow
ELEC_GREEN_BELOW=10
ELEC_RED_ABOVE=20
